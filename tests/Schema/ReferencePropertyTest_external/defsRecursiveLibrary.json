{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$defs": {
    "personDirect": {
      "$id": "#personDirect",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#personDirect"
          }
        }
      }
    },
    "personPath": {
      "$id": "#personPath",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/personPath"
          }
        }
      }
    }
  }
}
