{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "status_filter": {
            "oneOf": [
                {
                    "$ref": "#/$defs/MediaBuyStatus"
                },
                {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/MediaBuyStatus"
                    },
                    "minItems": 1
                }
            ],
            "description": "Filter by status. Can be a single status or array of statuses"
        }
    },
    "additionalProperties": true,
    "$defs": {
        "MediaBuyStatus": {
            "type": "string",
            "enum": [
                "pending_creatives",
                "pending_start",
                "active",
                "paused",
                "completed",
                "rejected",
                "canceled"
            ],
            "$id": "/schemas/3.1.0-beta.2/enums/media-buy-status.json"
        }
    }
}
