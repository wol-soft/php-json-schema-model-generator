                    if ($this->{{ property.getAttribute(true) }} === ${{ property.getAttribute(true) }}) {
                        return $this;
                    }

                    $value = $modelData['{{ property.getName() }}'] = ${{ property.getAttribute(true) }};

                    {% if generatorConfiguration.collectErrors() %}
