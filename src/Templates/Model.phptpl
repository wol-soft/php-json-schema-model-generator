             */
            protected function _process{{ viewHelper.ucfirst(property.getAttribute()) }}(array $modelData): void
            {
                {% if not generatorConfiguration.isImplicitNullAllowed() and not property.isRequired() %}
                    if (!array_key_exists('{{ property.getName() }}', $modelData) && $this->{{ property.getAttribute(true) }} === null) {
                        return;
